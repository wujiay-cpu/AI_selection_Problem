# ----------------------------------------------------------------------
# 1. 前端 Node.js / React / Vite
# ----------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# ----------------------------------------------------------------------
# 2. Python 基础与虚拟环境
# ----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
env.bak/
venv.bak/

# ----------------------------------------------------------------------
# 3. C++ / CMake / Pybind11 编译产物
# ----------------------------------------------------------------------
# CMake 产生的构建文件夹和缓存
build/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
*.cmake
.vs/
out/

# C/C++ 目标文件与静态库
*.o
*.obj
*.lib
*.a

# Python 动态链接库扩展 (极其重要：不要把这些编译好的二进制上传！)
*.pyd
*.so
*.dylib
*.dll
*.exe

# ----------------------------------------------------------------------
# 4. 业务运行数据
# ----------------------------------------------------------------------
# 只忽略运行结果，不要全局忽略 *.json（避免误伤配置文件）
results/

# ----------------------------------------------------------------------
# 5. 操作系统 / IDE 临时文件
# ----------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
